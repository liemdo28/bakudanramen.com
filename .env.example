# ─────────────────────────────────────────────────────────
#  Bakudan Ramen — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit the actual .env file to git.
# ─────────────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Public URL of the site (no trailing slash)
SITE_URL=https://bakudanramen.com

# JWT signing secret — change this to a long random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# Node environment
NODE_ENV=production
